{
  "name": "file-transfer-extension",
  "displayName": "File Transfer",
  "description": "Copy files between locations with a dual-pane interface",
  "version": "0.0.3",
  "publisher": "Erik Knutsson",
  "author": {
    "name": "Erik Knutsson",
    "email": "erik.knutsson@configura.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/erik-configura/File-Transfer-Extension.git"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:fileTransfer.openPanel",
    "onWebviewPanel:fileTransfer"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "fileTransfer.openPanel",
        "title": "Open File Transfer Panel"
      }
    ],
    "keybindings": [
      {
        "command": "fileTransfer.openPanel",
        "key": "ctrl+shift+f"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --platform=node --target=node16",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "esbuild-watch": "npm run esbuild-base -- --sourcemap --watch",
    "test": "jest --runInBand",
    "test-compile": "npm run test && tsc -p ./",
    "compile": "npm run test && tsc -p ./",
    "package": "npx vsce package"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^16.11.0",
    "@types/vscode": "^1.75.0",
    "@typescript-eslint/eslint-plugin": "^5.42.0",
    "@typescript-eslint/parser": "^5.42.0",
    "esbuild": "^0.15.10",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^4.7.4",
    "vsce": "^2.15.0"
  }
}
